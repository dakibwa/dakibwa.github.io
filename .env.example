APP_URL=http://localhost:3000
# Set to "portugal" when exporting this site under https://akibwa.com/portugal/.
NEXT_PUBLIC_SITE_BASE_PATH=
LESSON_PRICE_CENTS=2500
LESSON_CURRENCY=eur

# Preferred: custom calendar UI in this site, backed by a separate Square API adapter.
# Keep SQUARE_ACCESS_TOKEN and all Square secrets out of this static site.
NEXT_PUBLIC_BOOKING_MODE=custom-square
# Set this only after the Cloudflare Worker `/health` endpoint returns ok: true.
# NEXT_PUBLIC_BOOKING_API_BASE_URL=https://ines-booking-api.dakibwa.workers.dev
NEXT_PUBLIC_BOOKING_API_BASE_URL=

# Paste the real Square booking link or one-line iframe/button code here, then restart `npm run dev`.
# This remains the safe fallback and management link while the custom adapter is being connected.
# In Square: Appointments > Online booking > Channels > Add your booking flow to an existing site.
# NEXT_PUBLIC_SQUARE_BOOKING_URL=https://squareup.com/appointments/book/...
NEXT_PUBLIC_SQUARE_BOOKING_URL=

# Acuity fallback while Square setup is being tested.
# Use the full URL from Acuity Scheduling Page > Link, for example:
# NEXT_PUBLIC_ACUITY_SCHEDULER_URL=https://portuguese-with-ines.as.me/first-portuguese-lesson
NEXT_PUBLIC_ACUITY_SCHEDULER_URL=

# Temporary legacy fallback only. Leave blank for the Square-first production flow.
NEXT_PUBLIC_CALCOM_LINK=
