APP_URL=http://localhost:3000
# Set to "portugal" when exporting this site under https://akibwa.com/portugal/.
NEXT_PUBLIC_SITE_BASE_PATH=
LESSON_PRICE_CENTS=2000
NEXT_PUBLIC_LESSON_PRICE_CENTS=2000
LESSON_CURRENCY=eur
NEXT_PUBLIC_LESSON_DURATION_MINUTES=45
NEXT_PUBLIC_SAME_DAY_RESCHEDULE_FEE_CENTS=500
# Production currently uses manual enforcement for the same-day rule.
NEXT_PUBLIC_RESCHEDULE_FEE_MODE=manual

# Production: Square owns live availability, confirmation, and payment.
NEXT_PUBLIC_BOOKING_MODE=square-hosted
# Leave blank in hosted mode. Set only after a real Worker `/health` response.
# NEXT_PUBLIC_BOOKING_API_BASE_URL=https://ines-booking-api.dakibwa.workers.dev
NEXT_PUBLIC_BOOKING_API_BASE_URL=

# Paste the real Square booking link or one-line iframe/button code here.
# In Square: Appointments > Online booking > Channels > Add your booking flow to an existing site.
# NEXT_PUBLIC_SQUARE_BOOKING_URL=https://squareup.com/appointments/book/...
NEXT_PUBLIC_SQUARE_BOOKING_URL=

# Optional provider fallback.
# Use the full URL from Acuity Scheduling Page > Link, for example:
# NEXT_PUBLIC_ACUITY_SCHEDULER_URL=https://portuguese-with-ines.as.me/first-portuguese-lesson
NEXT_PUBLIC_ACUITY_SCHEDULER_URL=

# Legacy fallback only. Leave blank for the Square-first production flow.
NEXT_PUBLIC_CALCOM_LINK=
